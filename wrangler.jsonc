{
	"compatibility_date": "2026-04-30",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "website",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "WAITLIST_DB",
			"database_name": "onebrain-waitlist",
			"database_id": "96446beb-9407-4da8-9770-82946f85ebbd",
			"migrations_dir": "migrations"
		}
	]
}
