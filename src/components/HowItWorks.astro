---
const steps = [
  {
    n: '01',
    t: 'INITIATE',
    d: 'Install the CLI · run /onboarding · the agent learns your name, vault, and identity.',
    code: 'bun install -g @onebrain-ai/cli',
  },
  {
    n: '02',
    t: 'CAPTURE_INTENT',
    d: 'Talk to the agent in natural language. It writes, classifies, and links in real time.',
    code: '/braindump · /capture · /bookmark',
  },
  {
    n: '03',
    t: 'MUTUAL_EVOLUTION',
    d: '/research and /distill expand your knowledge. /learn deepens the agent. The loop tightens.',
    code: '/research · /distill · /learn',
  },
];
---

<section id="how" class="cyber-section reveal" style="--section-accent: #ffb000;">
  <div class="cyber-section-orb" aria-hidden="true"></div>
  <div class="cyber-section-grid" aria-hidden="true"></div>

  <div class="cyber-section-shell">
    <header class="cyber-section-head">
      <div class="cyber-pill">
        <span class="cyber-pill-dot"></span>
        <span>EXECUTION_PROTOCOL</span>
      </div>
      <h2 class="cyber-h2">
        The Path to<br/>
        <span class="cyber-h2-stroke" data-text="Unified Intelligence.">Unified Intelligence.</span>
      </h2>
    </header>

    <div class="grid md:grid-cols-3 gap-4">
      {steps.map((s) => (
        <div class="cyber-card step-card">
          <div class="step-num">{s.n}</div>
          <h3 class="cyber-card-title step-title">{s.t}</h3>
          <p class="cyber-card-desc">{s.d}</p>
          <code class="step-code">{s.code}</code>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .step-card {
    padding: 1.75rem 1.6rem 1.6rem;
    display: flex;
    flex-direction: column;
    min-height: 220px;
  }
  .step-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: 3rem;
    line-height: 1;
    color: var(--section-accent);
    text-shadow: 0 0 30px color-mix(in srgb, var(--section-accent) 50%, transparent);
    margin-bottom: 16px;
  }
  .step-title { letter-spacing: 0.08em; font-size: 0.95rem; }
  .step-code {
    margin-top: auto;
    padding-top: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.4);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin-top: 18px;
    padding-top: 14px;
    display: block;
  }
</style>
