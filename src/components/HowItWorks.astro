---
const steps = [
  {
    n: "01",
    title: "Install the plugin",
    body: "Add the OneBrain marketplace to Claude Code, install the plugin, and run /onboarding inside any Obsidian vault.",
  },
  {
    n: "02",
    title: "Capture as you think",
    body: "Talk to the agent in plain language. It writes to your vault, classifies, links, and updates memory in the background.",
  },
  {
    n: "03",
    title: "Synthesize on demand",
    body: "Ask /distill, /weekly, or /research when you want structure. Open the markdown in Obsidian — same files, two views.",
  },
];
---

<section id="how" class="mx-auto max-w-6xl px-6 py-20">
  <div class="text-center max-w-2xl mx-auto">
    <p class="text-sm uppercase tracking-widest text-[var(--color-accent-2)]">How it works</p>
    <h2 class="mt-3 text-3xl md:text-4xl font-semibold tracking-tight">Three steps to a working second brain.</h2>
  </div>

  <div class="mt-12 grid md:grid-cols-3 gap-4">
    {steps.map((s) => (
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/60 p-6">
        <div class="font-mono text-sm text-[var(--color-accent)]">{s.n}</div>
        <h3 class="mt-3 text-lg font-medium tracking-tight">{s.title}</h3>
        <p class="mt-2 text-sm text-[var(--color-muted)] leading-relaxed">{s.body}</p>
      </div>
    ))}
  </div>
</section>
