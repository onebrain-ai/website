---
---

<header class="sticky top-0 z-50 nav-glass">
  <div class="mx-auto max-w-7xl px-6 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-3 group relative">
      <div class="w-8 h-8 relative">
        <div class="absolute inset-0 bg-accent-2/20 blur-md opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <div class="absolute inset-0 border border-white/10 group-hover:border-[var(--color-accent-2)] transition-colors"></div>
        <div aria-hidden="true" class="absolute inset-0 flex items-center justify-center text-lg animate-pulse">🧠</div>
      </div>
      <div class="flex flex-col leading-none">
        <span class="font-black text-white tracking-tighter uppercase text-base">OneBrain</span>
        <span class="font-mono text-[9px] text-[var(--color-accent-2)] tracking-[0.2em] uppercase opacity-70">Unified Intelligence</span>
      </div>
    </a>

    <div class="hidden lg:flex items-center gap-8 font-mono text-[10px] tracking-[0.25em] uppercase text-[var(--color-muted)]">
      <a href="#features" class="hover:text-white transition-colors relative group">
        <span class="text-[var(--color-accent-2)] opacity-0 group-hover:opacity-100 mr-1 transition-opacity">[</span>Features<span class="text-[var(--color-accent-2)] opacity-0 group-hover:opacity-100 ml-1 transition-opacity">]</span>
      </a>
      <a href="#synergy" class="hover:text-white transition-colors relative group">
        <span class="text-[var(--color-accent-2)] opacity-0 group-hover:opacity-100 mr-1 transition-opacity">[</span>Synergy<span class="text-[var(--color-accent-2)] opacity-0 group-hover:opacity-100 ml-1 transition-opacity">]</span>
      </a>
      <a href="#how" class="hover:text-white transition-colors relative group">
        <span class="text-[var(--color-accent-2)] opacity-0 group-hover:opacity-100 mr-1 transition-opacity">[</span>How<span class="text-[var(--color-accent-2)] opacity-0 group-hover:opacity-100 ml-1 transition-opacity">]</span>
      </a>
      <a href="#commands" class="hover:text-white transition-colors relative group">
        <span class="text-[var(--color-accent-2)] opacity-0 group-hover:opacity-100 mr-1 transition-opacity">[</span>Commands<span class="text-[var(--color-accent-2)] opacity-0 group-hover:opacity-100 ml-1 transition-opacity">]</span>
      </a>
      <a href="#stack" class="hover:text-white transition-colors relative group">
        <span class="text-[var(--color-accent-2)] opacity-0 group-hover:opacity-100 mr-1 transition-opacity">[</span>Stack<span class="text-[var(--color-accent-2)] opacity-0 group-hover:opacity-100 ml-1 transition-opacity">]</span>
      </a>
      <a href="#cloud" class="hover:text-white transition-colors relative group">
        <span class="text-[var(--color-accent-2)] opacity-0 group-hover:opacity-100 mr-1 transition-opacity">[</span>Cloud<span class="text-[var(--color-accent-2)] opacity-0 group-hover:opacity-100 ml-1 transition-opacity">]</span>
      </a>
    </div>

    <div class="flex items-center gap-6">
      <a href="https://github.com/onebrain-ai/onebrain" class="hidden sm:flex font-mono text-[9px] tracking-widest uppercase text-white/40 hover:text-white transition-colors items-center gap-2">
        <span class="w-1 h-1 bg-[var(--color-accent-2)] rounded-full animate-ping"></span>
        GitHub::Repo
      </a>
      <a href="https://github.com/onebrain-ai/onebrain#installation" class="btn-tech h-10 w-32 group">
        <div class="btn-tech-inner">
          <span class="font-mono text-[10px] font-bold tracking-[0.15em] uppercase text-white group-hover:text-black">Initialize_</span>
        </div>
      </a>
    </div>
  </div>
</header>
