---
---

<section class="relative overflow-hidden">
  <div class="mx-auto max-w-6xl px-6 pt-24 pb-20 text-center">
    <p class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)]/60 px-3 py-1 text-xs text-[var(--color-muted)]">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]"></span>
      v2.2.2 — open source, MIT licensed
    </p>

    <h1 class="mt-6 text-5xl md:text-7xl font-semibold tracking-tight leading-[1.05]">
      Your second brain,
      <span class="block bg-gradient-to-r from-[var(--color-accent)] to-[var(--color-accent-2)] bg-clip-text text-transparent">
        powered by Claude Code.
      </span>
    </h1>

    <p class="mt-6 mx-auto max-w-2xl text-lg text-[var(--color-muted)]">
      OneBrain is a personal AI operating system that lives inside your Obsidian vault.
      Capture thoughts, synthesize knowledge, and let an agent work alongside you — all in plain markdown.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
      <a
        href="https://github.com/onebrain-ai/onebrain#install"
        class="px-5 py-3 rounded-lg bg-gradient-to-r from-[var(--color-accent)] to-[var(--color-accent-2)] text-[var(--color-bg)] font-medium hover:opacity-90 transition"
      >
        Get started — free
      </a>
      <a
        href="#cloud"
        class="px-5 py-3 rounded-lg border border-[var(--color-border)] hover:bg-[var(--color-surface)] transition"
      >
        Join Cloud waitlist
      </a>
    </div>

    <div class="mt-10 inline-flex items-center gap-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 font-mono text-sm">
      <span class="text-[var(--color-muted)]">$</span>
      <span>npm install -g <span class="text-[var(--color-accent-2)]">@onebrain-ai/cli</span></span>
    </div>

    <p class="mt-4 text-xs text-[var(--color-muted)]">
      Run OneBrain on cloud with <span class="text-[var(--color-text)]">onebrain.run</span> — coming soon.
    </p>
  </div>
</section>
