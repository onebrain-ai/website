---
const features = [
  {
    icon: "🧠",
    title: "Persistent memory",
    body: "Three-layer memory: identity, lazy-loaded topic files, and session logs. The agent remembers what matters.",
  },
  {
    icon: "📥",
    title: "Frictionless capture",
    body: "Braindump, capture, bookmark — pick whichever matches your thought. The agent classifies and links automatically.",
  },
  {
    icon: "🔍",
    title: "Local semantic search",
    body: "qmd indexes your vault for hybrid keyword + vector search. Recall a half-remembered idea in seconds.",
  },
  {
    icon: "🔗",
    title: "Auto-linking",
    body: "Every new note gets up to 3 wikilinks under a Related section, surfaced from your existing knowledge.",
  },
  {
    icon: "⚡",
    title: "Skills, not chat",
    body: "20+ slash commands wrap deep workflows: /research, /distill, /weekly, /consolidate, /doctor. Type, don't prompt.",
  },
  {
    icon: "📂",
    title: "PARA out of the box",
    body: "Projects, Areas, Resources, Knowledge, Archive, Logs — opinionated structure with sane defaults you can override.",
  },
];
---

<section id="features" class="mx-auto max-w-6xl px-6 py-20">
  <div class="text-center max-w-2xl mx-auto">
    <p class="text-sm uppercase tracking-widest text-[var(--color-accent-2)]">Features</p>
    <h2 class="mt-3 text-3xl md:text-4xl font-semibold tracking-tight">
      Built for thinking in markdown.
    </h2>
    <p class="mt-4 text-[var(--color-muted)]">
      Skills, memory, and search — designed to compose with the tools you already use.
    </p>
  </div>

  <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {features.map((f) => (
      <div class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/60 p-6 hover:bg-[var(--color-surface)] hover:border-[var(--color-accent)]/40 transition">
        <div class="text-2xl">{f.icon}</div>
        <h3 class="mt-4 font-medium tracking-tight">{f.title}</h3>
        <p class="mt-2 text-sm text-[var(--color-muted)] leading-relaxed">{f.body}</p>
      </div>
    ))}
  </div>
</section>
