---
const features = [
  { icon: '◉', t: 'Persistent Memory',     d: 'Three layers — who you are, what you taught, what we decided. Across every session.', c: 'MEM_LAYER' },
  { icon: '↘', t: 'Frictionless Capture',  d: 'Braindump, capture, bookmark — pick whichever matches your thought.',                  c: 'INTAKE_OS' },
  { icon: '◈', t: 'Semantic Search',       d: 'QMD hybrid keyword + vector search. Recall any idea in seconds.',                       c: 'VEC_MATRIX' },
  { icon: '⌘', t: 'Auto-Linking',          d: 'Every new note gets wikilinks pulled from your existing knowledge graph.',              c: 'LINK_SYNC' },
  { icon: '⚡', t: 'Skills System',         d: '20+ slash commands wrap deep workflows like research, distill, and weekly review.',     c: 'SKILL_API' },
  { icon: '▦', t: 'PARA Native',           d: 'Sane defaults for Projects, Areas, Resources, and Knowledge folders.',                  c: 'FS_STRUCT' },
];
---

<section id="features" class="cyber-section reveal" style="--section-accent: #00ff9d;">
  <div class="cyber-section-orb" aria-hidden="true"></div>
  <div class="cyber-section-grid" aria-hidden="true"></div>

  <div class="cyber-section-shell">
    <header class="cyber-section-head">
      <div class="cyber-pill">
        <span class="cyber-pill-dot"></span>
        <span>ONEBRAIN // CAPABILITIES</span>
      </div>
      <h2 class="cyber-h2">
        Built for<br/>
        <span class="cyber-h2-stroke" data-text="Synergetic Thinking.">Synergetic Thinking.</span>
      </h2>
      <p class="cyber-sub">
        OneBrain doesn't just store markdown. Every feature exists to make you and the agent better at each other's job.
      </p>
    </header>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {features.map((f) => (
        <div class="cyber-card feature-card">
          <span class="cyber-card-meta">{f.c}</span>
          <div class="feature-icon" aria-hidden="true">{f.icon}</div>
          <h3 class="cyber-card-title">{f.t}</h3>
          <p class="cyber-card-desc">{f.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-card { padding: 1.5rem 1.5rem 1.6rem; }
  .feature-icon {
    font-family: var(--font-mono);
    font-size: 22px;
    color: var(--section-accent);
    line-height: 1;
    margin-bottom: 14px;
    text-shadow: 0 0 16px var(--section-accent);
  }
</style>
